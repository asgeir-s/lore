{
  "identifier": "default",
  "description": "Default capabilities for Dump app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-zoom",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text"
  ]
}
